# KasaPOS Sync Agent Configuration
# Copy this file to .env and fill in your values

# ============================================
# E-Commerce Platform Settings
# ============================================
# Get these from your platform administrator
ECOMMERCE_API_URL=http://localhost:8000/api/v1
STORE_ID=your-store-id-here
API_KEY=your-api-key-here

# ============================================
# KasaPOS Connection Settings
# ============================================
# Connection type: mysql, sqlite, csv, or excel
KASAPOS_CONNECTION_TYPE=mysql

# MySQL Settings (if connection_type is mysql)
KASAPOS_MYSQL_HOST=localhost
KASAPOS_MYSQL_PORT=3306
KASAPOS_MYSQL_USER=root
KASAPOS_MYSQL_PASSWORD=your-password
KASAPOS_MYSQL_DATABASE=kasapos

# SQLite Settings (if connection_type is sqlite)
# Path to KasaPOS SQLite database file
KASAPOS_SQLITE_PATH=C:\KasaPOS\data\kasapos.db

# CSV/Excel Settings (if connection_type is csv or excel)
# Folder where KasaPOS exports files
KASAPOS_EXPORT_FOLDER=C:\KasaPOS\exports
KASAPOS_PRODUCTS_FILE=products.csv
KASAPOS_INVENTORY_FILE=inventory.csv
KASAPOS_ORDERS_FILE=sales.csv

# ============================================
# Store Settings
# ============================================
KASAPOS_STORE_CODE=STORE001

# ============================================
# Sync Settings
# ============================================
# Sync interval in minutes (default: 5)
KASAPOS_SYNC_INTERVAL=5
# Inventory sync interval in minutes during business hours (default: 1)
KASAPOS_INVENTORY_INTERVAL=1
